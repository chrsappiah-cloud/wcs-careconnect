{
  "app": "npx ts-node bin/careconnect.ts",
  "watch": {
    "include": ["**"],
    "exclude": ["README.md", "cdk*.json", "**/*.d.ts", "**/*.generated.ts", "dist/**/*", "node_modules/**/*"]
  },
  "context": {
    "@aws-cdk/aws-apigateway:resourcePolicy": true,
    "@aws-cdk/aws-codedeploy:removeAlarmsFromDeploymentGroup": true,
    "@aws-cdk/aws-ec2:restrictDefaultSecurityGroup": true,
    "@aws-cdk/aws-ecs:arnFormatIncludesClusterName": true,
    "@aws-cdk/aws-rds:breakCircularDependency": true,
    "@aws-cdk/aws-s3:createDefaultLoggingPolicy": true,
    "aws-cdk-lib/aws-s3:serverAccessLogsUseBucketPolicy": true,
    "@aws-cdk/core:validateSnapshotRemovalPolicy": true
  }
}
