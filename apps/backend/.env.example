# ─────────────────────────────────────────────────────────────────────────────
# CareConnect Backend — Environment Variables
# Copy to .env and fill in values. Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production
PORT=3001

# ── Database ─────────────────────────────────────────────────────────────────
# Option A: single connection string (Supabase / local dev)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Option B: individual vars — used by ECS/Fargate (injected from Secrets Manager)
# DB_HOST=careconnect.cluster-xxxx.ap-southeast-2.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=careconnect
# DB_USER=careconnect_admin
# DB_PASSWORD=
# DB_POOL_MAX=10
# DB_IDLE_TIMEOUT=30000
# DB_CONNECT_TIMEOUT=5000

# ── RDS SSL (production only) ────────────────────────────────────────────────
# Path to the RDS global CA bundle. Baked into the Docker image at build time.
# Download: https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
# RDS_CA_BUNDLE=/app/certs/global-bundle.pem

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-2

# ── S3 — resident photos ─────────────────────────────────────────────────────
# Bucket name is output by CDK as CareConnectPhotosBucket
S3_BUCKET=careconnect-resident-photos-123456789012

# ── Amazon Cognito ───────────────────────────────────────────────────────────
# Output by CDK as CareConnectUserPoolId / CareConnectCognitoClientId
COGNITO_USER_POOL_ID=ap-southeast-2_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
